# Example .env file — copy to .env and fill values for your environment

# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

# Database (do NOT commit production credentials)
#DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Redis (optional)
#REDIS_URL=redis://localhost:6379/0

# JWT secret
#JWT_SECRET_KEY=your-very-secret-key

# Vault (optional)
#VAULT_ADDR=https://vault.example.com
#VAULT_TOKEN=your-vault-token

# Doppler (optional)
#DOPPLER_TOKEN=...
